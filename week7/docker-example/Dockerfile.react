# Multi-stage build: Stage 1 builds the React app, Stage 2 serves it with nginx.
# This keeps the final image small -- it doesn't carry Node.js or node_modules,
# just the compiled static files and a lightweight web server.

# ---- Stage 1: Build ----
FROM node:20-alpine AS build
WORKDIR /app
COPY package*.json ./
RUN npm ci
COPY . .
RUN npm run build

# ---- Stage 2: Serve ----
FROM nginx:alpine
COPY --from=build /app/build /usr/share/nginx/html
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
